{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/lint_go.py",
            "timeout": 60,
            "statusMessage": "Running golangci-lint..."
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/lint_ts.py",
            "timeout": 60,
            "statusMessage": "Running tsc lint..."
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/lint_js.py",
            "timeout": 30,
            "statusMessage": "Running ESLint..."
          }
        ]
      }
    ]
  }
}
